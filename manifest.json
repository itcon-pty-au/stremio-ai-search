{
    "id": "community.aisearch",
    "version": "1.0.0",
    "name": "AI Search",
    "description": "Search for movies and series using AI",
    "resources": ["catalog"],
    "types": ["movie", "series"],
    "catalogs": [
        {
            "type": "movie",
            "id": "aisearch.movies",
            "name": "AI Movie Search",
            "extra": [{ "name": "search", "isRequired": true }]
        },
        {
            "type": "series",
            "id": "aisearch.series",
            "name": "AI Series Search", 
            "extra": [{ "name": "search", "isRequired": true }]
        }
    ],
    "behaviorHints": {
        "adult": false,
        "configurable": true
    },
    "transportName": "http",
    "transportUrl": "https://itcon-pty-au.github.io/stremio-ai-search/manifest.json",
    "idPrefixes": ["ai_"]
} 