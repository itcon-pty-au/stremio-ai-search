{
    "id": "org.itcon.aisearch",
    "version": "1.0.0",
    "name": "AI Search",
    "description": "AI-powered search for Stremio",
    "resources": ["catalog", "search"],
    "types": ["movie", "series"],
    "catalogs": [
        {
            "type": "movie",
            "id": "ai-search-movies",
            "name": "AI Search Results",
            "extra": [
                {
                    "name": "search",
                    "isRequired": true
                }
            ]
        },
        {
            "type": "series",
            "id": "ai-search-series",
            "name": "AI Search Results",
            "extra": [
                {
                    "name": "search",
                    "isRequired": true
                }
            ]
        }
    ],
    "behaviorHints": {
        "adult": false,
        "configurable": true
    },
    "transportName": "http",
    "transportUrl": "https://itcon-pty-au.github.io/stremio-ai-search/config.json",
    "configurationRequired": true,
    "config": {
        "type": "page",
        "url": "https://itcon-pty-au.github.io/stremio-ai-search/configure.html",
        "required": true
    }
} 