{
    "id": "community.aisearch",
    "version": "1.0.0",
    "name": "AI Search",
    "description": "Search for movies and series using AI",
    "resources": ["catalog"],
    "types": ["movie", "series"],
    "catalogs": [
        {
            "type": "movie",
            "id": "search",
            "name": "Search Movies",
            "extra": [{ "name": "search", "isRequired": true }]
        },
        {
            "type": "series",
            "id": "search",
            "name": "Search Series", 
            "extra": [{ "name": "search", "isRequired": true }]
        }
    ],
    "behaviorHints": {
        "adult": false,
        "configurable": true
    },
    "transportName": "http",
    "transportUrl": "https://itcon-pty-au.github.io/stremio-ai-search/config.json",
    "configurationRequired": true,
    "config": {
        "type": "page",
        "url": "https://itcon-pty-au.github.io/stremio-ai-search/configure.html",
        "required": true
    }
} 